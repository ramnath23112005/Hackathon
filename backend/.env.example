APP_NAME=InternetOS API
APP_VERSION=0.3.0
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Anakin API (SDK uses ANAKIN_API_KEY env var or api_key param)
WIRE_API_KEY=
WIRE_BASE_URL=https://api.anakin.io/v1
WIRE_TIMEOUT=60

# Wire action IDs (from Wire library dashboard)
WIRE_ACTION_REDDIT=rt_search
WIRE_ACTION_NEWS=gn_search

# LLM (OpenAI-compatible — e.g. Groq, OpenRouter, OpenAI)
LLM_ENABLED=true
OPENAI_API_KEY=gsk_...
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2
