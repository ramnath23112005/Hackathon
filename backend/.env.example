APP_NAME=InternetOS API
APP_VERSION=1.0.0
DEBUG=false

# CORS — add your production frontend URL here
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://hackathon-navy-eta.vercel.app"]

# Anakin Wire API (live internet data — get free credits at https://anakin.io)
# 500 free credits on signup, then fill https://forms.gle/SGRNyf5KY6LDAAcq9 for 250 more
WIRE_API_KEY=ask_your_key_here
WIRE_BASE_URL=https://api.anakin.io/v1
WIRE_TIMEOUT=30

# Wire action IDs (from Wire library dashboard)
WIRE_ACTION_X=tw_search
WIRE_ACTION_REDDIT=rt_search
WIRE_ACTION_NEWS=gn_search

# LLM (OpenAI-compatible — e.g. Groq, OpenRouter, OpenAI)
LLM_ENABLED=true
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=2

# Demo Mode — when true, uses cached responses (safe for live judging)
DEMO_MODE=false
